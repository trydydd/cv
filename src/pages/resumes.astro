---
import SiteLayout from '../layouts/SiteLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import ResumeCard from '../components/ResumeCard.astro';
import { getGalleryResumes, loadSiteConfig } from '../lib/config';

const siteConfig = loadSiteConfig();
const resumes = getGalleryResumes();
---
<SiteLayout title={`Resume Gallery · ${siteConfig.site.title}`} description="Compare resume pages generated by different AI models from the same source data and prompt.">
  <SiteNav />
  <main id="main" class="container">
    <header class="page-header">
      <h1 class="page-title">Resume experiment gallery</h1>
      <p class="lede">Same source data. Same prompt. Different models. Each entry below is a complete resume page authored end-to-end by the model it names, so you can compare what each one shipped.</p>
      <p class="source-links">
        <a href="https://github.com/trydydd/cv/blob/main/inputs/resume.yaml">View source data</a>
        <span aria-hidden="true"> · </span>
        <a href="https://github.com/trydydd/cv/blob/main/inputs/prompt.md">View prompt</a>
      </p>
    </header>
    {resumes.length > 0 ? (
      <section class="ledger" aria-label="Resume variants">
        {resumes.map((resume) => <ResumeCard resume={resume} />)}
      </section>
    ) : (
      <p class="lede">No resume variants are published right now. The gold-standard resume is still one click away on the home page.</p>
    )}
  </main>
</SiteLayout>
