---
import SiteLayout from '../layouts/SiteLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import { loadSiteConfig, resolveRoleTarget } from '../lib/config';

const siteConfig = loadSiteConfig();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resumeHref = `${base}${resolveRoleTarget('everyone', siteConfig)}`;
const galleryHref = `${base}${resolveRoleTarget('tech', siteConfig)}`;
---
<SiteLayout title={`Not found · ${siteConfig.site.title}`}>
  <SiteNav />
  <main id="main" class="container page-header">
    <p class="kicker">404</p>
    <h1 class="page-title">That page is not here.</h1>
    <p class="lede">This site has exactly three destinations: the resume, the gallery, and this page. You've found the third one.</p>
    <div class="actions">
      <a class="button primary" href={resumeHref}>{siteConfig.roles.everyone.label}</a>
      <a class="button secondary" href={galleryHref}>{siteConfig.roles.tech.label}</a>
    </div>
  </main>
</SiteLayout>
