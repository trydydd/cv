---
import SiteLayout from '../../layouts/SiteLayout.astro';
import SiteNav from '../../components/SiteNav.astro';
import ResumeDocument from '../../components/ResumeDocument.astro';
import MetadataPanel from '../../components/MetadataPanel.astro';
import { getEnabledResumes, getResumeById } from '../../lib/config';
import type { StructuredResumeEntry } from '../../lib/types';

export function getStaticPaths() {
  return getEnabledResumes()
    .filter((resume) => resume.candidate)
    .map((resume) => ({ params: { id: resume.id } }));
}

const { id } = Astro.params;
const found = id ? getResumeById(id) : undefined;
if (!found || !found.candidate) return Astro.redirect('/cv/404');
const resume = found as StructuredResumeEntry;
const pageTitle = resume.isGoldCandidate ? `${resume.candidate.name} · Resume` : `${resume.label} · Resume Gallery`;
---
<SiteLayout title={pageTitle} description={resume.description}>
  <SiteNav />
  <main id="main" class="container">
    {!resume.isGoldCandidate && (
      <header class="page-header">
        <div class="badges">
          <span class="badge">{resume.tier}</span>
        </div>
        <p class="kicker">{resume.label}</p>
        <p class="lede">{resume.description}</p>
      </header>
    )}
    <div class="resume-layout">
      <ResumeDocument resume={resume} />
      <MetadataPanel resume={resume} />
    </div>
  </main>
</SiteLayout>
