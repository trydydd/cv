---
import SiteLayout from '../layouts/SiteLayout.astro';
import RoleSelector from '../components/RoleSelector.astro';
import SiteNav from '../components/SiteNav.astro';
import { loadResumeRegistry, loadSiteConfig, validateSiteConfig } from '../lib/config';

const siteConfig = loadSiteConfig();
const registry = loadResumeRegistry();
validateSiteConfig(siteConfig, registry);
---
<SiteLayout title={siteConfig.site.title} description={siteConfig.site.description}>
  <SiteNav />
  <main id="main" class="hero container">
    <p class="kicker">Principal Engineer · Applied AI &amp; Enterprise Platform Architecture</p>
    <h1 class="hero-name">Willard Hucks</h1>
    <p class="lede">Fourteen years across infrastructure, DevOps, and platform architecture — now setting enterprise direction for applied AI: local inference, agentic systems, and the governance that makes them shippable.</p>
    <RoleSelector siteConfig={siteConfig} />
  </main>
</SiteLayout>
