---
import { loadSiteConfig } from '../lib/config';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteConfig = loadSiteConfig();
const resumeHref = `${base}/resume/${siteConfig.goldResumeId}`;
const path = Astro.url.pathname;
const isResume = path.startsWith(`${base}/resume/`);
const isGallery = path.startsWith(`${base}/resumes`) || path.startsWith(`${base}/gallery`);
---
<nav class="site-nav container" aria-label="Primary navigation">
  <a class="brand-mark" href={`${base}/`}>Willard Hucks</a>
  <div class="nav-links">
    <a href={resumeHref} aria-current={isResume ? 'page' : undefined}>{siteConfig.roles.everyone.label}</a>
    <a href={`${base}/resumes`} aria-current={isGallery ? 'page' : undefined}>{siteConfig.roles.tech.label}</a>
  </div>
</nav>
