---
import type { ResumeEntry } from '../lib/types';
interface Props { resume: ResumeEntry; }
const { resume } = Astro.props;

const tags = [
  resume.tier,
  resume.pageUrl && 'model-authored page',
].filter(Boolean);
---
<a class="ledger-row" href={resume.pageUrl ?? `/cv/resume/${resume.id}`}>
  <div>
    <h2>{resume.label}{resume.pageUrl && <span class="ext" aria-hidden="true"> &#8599;</span>}</h2>
    <p class="entry-desc">{resume.description}</p>
  </div>
  <div class="ledger-meta">
    <span class="tags">{tags.join(' · ')}</span>
    <span>{resume.provider} · {resume.model}</span>
  </div>
</a>
