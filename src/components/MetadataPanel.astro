---
import type { ResumeEntry } from '../lib/types';
interface Props { resume: ResumeEntry; }
const { resume } = Astro.props;
const candidate = resume.candidate;

const sections = candidate && [
  'summary' in candidate && { id: 'summary', label: 'Summary' },
  Array.isArray(candidate.highlights) && candidate.highlights.length > 0 && { id: 'impact', label: 'Selected Impact' },
  candidate.experience && { id: 'experience', label: 'Experience' },
  candidate.projects && { id: 'projects', label: 'Projects' },
  candidate.community && { id: 'community', label: 'Community' },
  candidate.skills && { id: 'skills', label: 'Skills' },
  candidate.education_and_honors && { id: 'education', label: 'Education & Honors' },
].filter((s): s is { id: string; label: string } => Boolean(s));

const generated = new Date(resume.generatedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC',
});

// Provenance must be verifiable, not just asserted: prompt and source link
// to the exact versioned files the hash and version refer to.
const repo = 'https://github.com/trydydd/cv';
const promptHref = `${repo}/blob/main/inputs/prompt.md`;
const sourceHref = `${repo}/blob/main/${resume.candidateSource ?? 'inputs/resume.yaml'}`;
---
<aside class="metadata-panel" aria-label="Resume version details">
  {resume.pdfPath && <a class="button secondary" href={resume.pdfPath}>Download PDF</a>}
  {sections && sections.length > 1 && (
    <nav class="jump-list" aria-label="Jump to section">
      {sections.map((section) => <a href={`#${section.id}`}>{section.label}</a>)}
    </nav>
  )}
  <details>
    <summary>About this version</summary>
    <dl class="metadata-list">
      <div><dt>Provider</dt><dd>{resume.provider}</dd></div>
      <div><dt>Model</dt><dd>{resume.model}</dd></div>
      <div><dt>Tier</dt><dd>{resume.tier}</dd></div>
      <div><dt>Prompt</dt><dd><a href={promptHref}>v{resume.promptVersion}</a></dd></div>
      <div><dt>Generated</dt><dd>{generated}</dd></div>
      <div><dt>Source hash</dt><dd><a href={sourceHref}>{resume.resumeHash}</a></dd></div>
    </dl>
  </details>
</aside>
