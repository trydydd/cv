---
import type { SiteConfig } from '../lib/types';
import { resolveRoleTarget } from '../lib/config';

interface Props { siteConfig: SiteConfig; }
const { siteConfig } = Astro.props;

const entries = [
  { role: siteConfig.roles.everyone, href: `/cv${resolveRoleTarget('everyone', siteConfig)}` },
  { role: siteConfig.roles.tech, href: `/cv${resolveRoleTarget('tech', siteConfig)}` },
];
---
<nav class="contents" aria-label="Contents">
  <p class="contents-heading">Contents</p>
  {entries.map(({ role, href }) => (
    <a class="contents-entry" href={href}>
      <div>
        <span class="entry-title">{role.label}</span>
        <p class="entry-desc">{role.description}</p>
      </div>
      <span class="arrow" aria-hidden="true">&rarr;</span>
    </a>
  ))}
</nav>
