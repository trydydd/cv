---
import type { SiteConfig } from '../lib/types';
import { resolveRoleTarget } from '../lib/config';

interface Props { siteConfig: SiteConfig; }
const { siteConfig } = Astro.props;
const everyoneHref = `/cv${resolveRoleTarget('everyone', siteConfig)}`;
const techHref = `/cv${resolveRoleTarget('tech', siteConfig)}`;
---
<section class="role-panel" aria-labelledby="choose-role">
  <p class="kicker">Choose your path</p>
  <h2 id="choose-role">Who is viewing?</h2>
  <div class="role-actions">
    <a class="button primary" href={everyoneHref}>{siteConfig.roles.everyone.label}</a>
    <a class="button secondary" href={techHref}>{siteConfig.roles.tech.label}</a>
  </div>
</section>
